# BC Parks API
BCPARKS_BASE_URL=https://camping.bcparks.ca
REQUEST_DELAY_MS=500
SESSION_CACHE_TTL_MINUTES=30

# Monitoring
MONITOR_INTERVAL_SECONDS=300
MORNING_CHECK_ENABLED=true
MORNING_PRE_CHECK_SECONDS=5

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL_TO=your-email@gmail.com

# Webhook Notifications (optional)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Auto-Cart (hunt/monitor commands)
AUTO_CART_ENABLED=true
AUTO_CART_HEADLESS=false
AUTO_CART_PRE_WARM_MINUTES=2

# Booking Automation
BOOKING_HEADLESS=false

# Search Defaults
DEFAULT_PARTY_SIZE=2
DEFAULT_EQUIPMENT_CATEGORY_ID=-32768
